generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

enum IdeaStatus {
  ACTIVE
  PAUSED
  BACKLOG
  SHIPPED
  ABANDONED
}

enum IdeaCategory {
  ML_RESEARCH
  ML_PRODUCT
  WEB_APP
  MOBILE_APP
  TOOL
  PLATFORM
  API_SERVICE
  CONTENT
  BUSINESS
  OTHER
}

enum MilestoneStatus {
  TODO
  IN_PROGRESS
  DONE
  SKIPPED
}

enum AnalysisType {
  FULL_ANALYSIS
  MILESTONE_PLAN
  CONTEXT_RESTORE
  MARKET_RESEARCH
  STRATEGIC_REVIEW
  DAILY_FOCUS
  TAG_SUGGESTION
}

enum AIModel {
  HAIKU_4_5
  SONNET_4_6
  OPUS_4_6
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  password      String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  ideas         Idea[]
  sessions      WorkSession[]
  weeklyReviews WeeklyReview[]
  preferences   UserPreferences?
  @@map("users")
}

model UserPreferences {
  id                   String       @id @default(cuid())
  userId               String       @unique
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultCategory      IdeaCategory @default(OTHER)
  dailyFocusEnabled    Boolean      @default(true)
  weeklyReviewEnabled  Boolean      @default(true)
  weeklyReviewDay      Int          @default(1)
  weeklyReviewHour     Int          @default(9)
  notificationsEnabled Boolean      @default(true)
  updatedAt            DateTime     @updatedAt
  @@map("user_preferences")
}

model Idea {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  description    String?         @db.Text
  status         IdeaStatus      @default(BACKLOG)
  category       IdeaCategory    @default(OTHER)
  tags           String[]        @default([])
  priority       Int             @default(0)
  isPinned       Boolean         @default(false)
  momentumScore  Float           @default(0)
  totalTimeHours Float           @default(0)
  sessionCount   Int             @default(0)
  lastWorkedAt   DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  startedAt      DateTime?
  shippedAt      DateTime?
  abandonedAt    DateTime?
  sessions       WorkSession[]
  milestones     Milestone[]
  analysis       AIAnalysis[]
  chatMessages   ChatMessage[]
  embedding      IdeaEmbedding?
  relationships  IdeaRelationship[] @relation("SourceIdea")
  relatedTo      IdeaRelationship[] @relation("TargetIdea")
  notes          Note[]
  @@index([userId, status])
  @@index([userId, momentumScore(sort: Desc)])
  @@index([userId, lastWorkedAt(sort: Desc)])
  @@map("ideas")
}

model IdeaEmbedding {
  id        String   @id @default(cuid())
  ideaId    String   @unique
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  embedding Unsupported("vector(1536)")?
  updatedAt DateTime @updatedAt
  @@map("idea_embeddings")
}

model IdeaRelationship {
  id           String   @id @default(cuid())
  sourceId     String
  targetId     String
  source       Idea     @relation("SourceIdea", fields: [sourceId], references: [id], onDelete: Cascade)
  target       Idea     @relation("TargetIdea", fields: [targetId], references: [id], onDelete: Cascade)
  relationship String
  confidence   Float
  aiGenerated  Boolean  @default(true)
  createdAt    DateTime @default(now())
  @@unique([sourceId, targetId, relationship])
  @@map("idea_relationships")
}

model WorkSession {
  id               String    @id @default(cuid())
  ideaId           String
  idea             Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  durationMin      Int?
  goalForSession   String?   @db.Text
  whatAccomplished String?   @db.Text
  notes            String?   @db.Text
  @@index([ideaId])
  @@index([userId, startedAt(sort: Desc)])
  @@map("work_sessions")
}

model Milestone {
  id          String          @id @default(cuid())
  ideaId      String
  idea        Idea            @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  title       String
  description String?         @db.Text
  status      MilestoneStatus @default(TODO)
  orderIndex  Int             @default(0)
  dueDate     DateTime?
  completedAt DateTime?
  aiGenerated Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([ideaId, orderIndex])
  @@map("milestones")
}

model Note {
  id        String   @id @default(cuid())
  ideaId    String
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  isVoice   Boolean  @default(false)
  audioUrl  String?
  createdAt DateTime @default(now())
  @@index([ideaId, createdAt(sort: Desc)])
  @@map("notes")
}

model ChatMessage {
  id        String    @id @default(cuid())
  ideaId    String
  idea      Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  role      String
  content   String    @db.Text
  model     AIModel?
  tokens    Int?
  createdAt DateTime  @default(now())
  @@index([ideaId, createdAt])
  @@map("chat_messages")
}

model AIAnalysis {
  id           String       @id @default(cuid())
  ideaId       String
  idea         Idea         @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  model        AIModel
  analysisType AnalysisType
  result       Json
  promptTokens Int
  outputTokens Int
  costUsd      Float
  createdAt    DateTime     @default(now())
  @@index([ideaId, analysisType, createdAt(sort: Desc)])
  @@map("ai_analysis")
}

model WeeklyReview {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekOf       DateTime
  content      String   @db.Text
  ideasCovered String[]
  model        AIModel  @default(OPUS_4_6)
  tokens       Int
  costUsd      Float
  createdAt    DateTime @default(now())
  @@unique([userId, weekOf])
  @@map("weekly_reviews")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
